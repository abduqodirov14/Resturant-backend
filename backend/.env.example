# Database (Pooled connection for Vercel serverless)
DATABASE_URL="postgresql://user:password@host:5432/dbname?pgbouncer=true&connect_timeout=15&sslmode=require"

# Direct connection (for prisma migrate only)
DIRECT_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# Upstash Redis (from Vercel Marketplace)
REDIS_URL="rediss://default:xxxx@xxxx.upstash.io:6379"

# JWT secret
JWT_SECRET="your-super-secret-jwt-key-change-this"

# Admin token (frontend VITE_ADMIN_TOKEN must match this value)
ADMIN_TOKEN="admin123"

# Vercel Blob
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxxxxxx"

# Base URL for QR codes
NEXT_PUBLIC_BASE_URL="http://localhost:5173"
